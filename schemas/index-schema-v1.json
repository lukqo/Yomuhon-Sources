{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Yomuhon Source Index V1",
  "type": "object",
  "required": ["schemaVersion", "updatedAt", "minimumAppVersion", "sources"],
  "properties": {
    "schemaVersion": {"type": "integer", "const": 1},
    "updatedAt": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "minimumAppVersion": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "version", "language", "kind", "url", "enabled", "experimental", "status", "allowedDomains"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
          "name": {"type": "string", "minLength": 1},
          "version": {"type": "integer", "minimum": 1},
          "language": {"type": "string", "minLength": 2},
          "kind": {"enum": ["declarative-html", "declarative-json-api"]},
          "url": {"type": "string", "format": "uri", "pattern": "^https://"},
          "enabled": {"type": "boolean"}, "experimental": {"type": "boolean"},
          "status": {"enum": ["stable", "testing", "broken", "disabled", "deprecated"]},
          "allowedDomains": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "notes": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
