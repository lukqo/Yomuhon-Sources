{
  "schemaVersion": 1,
  "id": "zonatmo_es",
  "name": "ZonaTMO",
  "version": 1,
  "language": "es",
  "baseURL": "https://zonatmo.org",
  "engineMode": "html",
  "enabledByDefault": false,
  "experimental": true,
  "allowedDomains": [
    "zonatmo.org",
    "storage.zonatmo.org",
    "storage2.zonatmo.org"
  ],
  "supports": {
    "search": true,
    "popular": true,
    "details": true,
    "chapters": true,
    "pages": true,
    "genres": false
  },
  "network": {
    "headers": {
      "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
      "User-Agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 12_7) AppleWebKit/605.1.15 (KHTML, like Gecko) Yomuhon/1.0",
      "Referer": "https://zonatmo.org/"
    }
  },
  "routes": {
    "popular": {
      "path": "/"
    },
    "search": {
      "path": "/",
      "query": {
        "q": "{{query}}"
      }
    }
  },
  "selectors": {
    "popular": {
      "container": "a[href*='/library/']",
      "title": {
        "attrs": [
          "text",
          "title"
        ],
        "cleanup": [
          "decodeEntities",
          "normalizeWhitespace"
        ]
      },
      "url": {
        "attrs": [
          "href"
        ],
        "required": true
      },
      "cover": {
        "selectors": [
          "img"
        ],
        "attrs": [
          "data-src",
          "data-original",
          "data-lazy-src",
          "src"
        ]
      },
      "htmlScope": {
        "afterRegex": ">\\s*Populares\\s*<",
        "beforeRegex": ">\\s*Ver todo\\s*<"
      }
    },
    "search": {
      "container": "a[href*='/library/']",
      "title": {
        "attrs": [
          "text",
          "title"
        ],
        "cleanup": [
          "decodeEntities",
          "normalizeWhitespace"
        ]
      },
      "url": {
        "attrs": [
          "href"
        ],
        "required": true
      },
      "cover": {
        "selectors": [
          "img"
        ],
        "attrs": [
          "data-src",
          "data-original",
          "data-lazy-src",
          "src"
        ]
      }
    },
    "details": {
      "title": {
        "selectors": [
          "h1",
          "meta[property='og:title']"
        ],
        "attrs": [
          "text",
          "content"
        ],
        "cleanup": [
          "decodeEntities",
          "normalizeWhitespace"
        ]
      },
      "synopsis": {
        "selectors": [
          "meta[name='description']",
          "meta[property='og:description']"
        ],
        "attrs": [
          "content"
        ],
        "cleanup": [
          "stripHTML",
          "decodeEntities",
          "normalizeWhitespace"
        ]
      },
      "cover": {
        "selectors": [
          "meta[property='og:image']",
          "img"
        ],
        "attrs": [
          "content",
          "data-src",
          "data-original",
          "data-lazy-src",
          "src"
        ]
      }
    },
    "chapters": {
      "container": "li",
      "title": {
        "attrs": [
          "text"
        ],
        "cleanup": [
          "decodeEntities",
          "normalizeWhitespace"
        ]
      },
      "url": {
        "selectors": [
          "a[href*='/viewer/']",
          "a[href*='/chapter/']",
          "a[href*='/read/']"
        ],
        "attrs": [
          "href"
        ],
        "required": true
      },
      "number": {
        "from": "text",
        "regex": "(?:Cap[ií]tulo|Chapter)\\s*([0-9]+(?:\\.[0-9]+)?)"
      },
      "sort": "numberAscending"
    },
    "pages": {
      "extractors": [
        {
          "type": "css",
          "selector": "img[src*='zonatmo.org'], img[data-src*='zonatmo.org'], img[src*='/storage/'], img[data-src*='/storage/']",
          "attrs": [
            "data-src",
            "data-original",
            "data-lazy-src",
            "srcset",
            "src"
          ]
        },
        {
          "type": "regex",
          "pattern": "(https?:\\\\?/\\\\?/(?:storage2?\\.)?zonatmo\\.org/[^\\\"']+?\\.(?:jpg|jpeg|png|webp)(?:\\?[^\\\"']*)?)"
        }
      ],
      "filters": {
        "mustContain": [
          ".jpg",
          ".jpeg",
          ".png",
          ".webp"
        ],
        "blockContains": [
          "logo",
          "avatar",
          "placeholder",
          "banner",
          "ads/",
          "icon",
          "favicon",
          "sprite",
          "gravatar",
          "covers/"
        ]
      }
    }
  },
  "cleanup": {
    "decodeHTMLEntities": true,
    "normalizeWhitespace": true,
    "removeText": [
      "TU MANGA ONLINE",
      "ZonaTMO",
      "Leer online"
    ]
  },
  "tests": {
    "query": "gachiakuta",
    "minSearchResults": 1,
    "minChapters": 1,
    "minPages": 1
  }
}
