{
  "schemaVersion": 1,
  "id": "mangakatana_json",
  "name": "MangaKatana JSON",
  "version": 7,
  "language": "en",
  "baseURL": "https://mangakatana.com",
  "engineMode": "html",
  "enabledByDefault": false,
  "experimental": true,
  "allowedDomains": [
    "mangakatana.com",
    "i.mkklcdnv6tempv2.com",
    "i.mkklcdnv6.com"
  ],
  "supports": {
    "search": true,
    "popular": true,
    "details": true,
    "chapters": true,
    "pages": true,
    "genres": true
  },
  "network": {
    "headers": {
      "User-Agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 12_7) AppleWebKit/605.1.15 (KHTML, like Gecko) Yomuhon/1.0",
      "Referer": "https://mangakatana.com/"
    }
  },
  "routes": {
    "popular": {
      "path": "/"
    },
    "search": {
      "path": "/",
      "query": {
        "search": "{{query}}",
        "search_by": "book_name"
      }
    }
  },
  "selectors": {
    "popular": {
      "container": "a[href*=\"/manga/\"]",
      "title": {
        "attrs": [
          "text"
        ],
        "cleanup": [
          "decodeEntities",
          "normalizeWhitespace"
        ]
      },
      "url": {
        "attrs": [
          "href"
        ],
        "required": true
      },
      "cover": {
        "selectors": [
          "img"
        ],
        "attrs": [
          "src",
          "data-src",
          "data-original",
          "data-lazy-src"
        ]
      },
      "htmlScope": {
        "afterRegex": ">\\s*Hot Manga\\s*<",
        "beforeRegex": "<footer\\b"
      }
    },
    "search": {
      "container": "div#book_list div.item",
      "title": {
        "selectors": [
          "div.text h3 a"
        ],
        "attrs": [
          "text"
        ],
        "cleanup": [
          "decodeEntities",
          "normalizeWhitespace"
        ]
      },
      "url": {
        "selectors": [
          "div.text h3 a"
        ],
        "attrs": [
          "href"
        ],
        "required": true
      },
      "cover": {
        "selectors": [
          "img"
        ],
        "attrs": [
          "data-src",
          "data-original",
          "data-lazy-src",
          "src"
        ]
      }
    },
    "details": {
      "title": {
        "selectors": [
          "h1.heading"
        ],
        "attrs": [
          "text"
        ],
        "cleanup": [
          "decodeEntities",
          "normalizeWhitespace"
        ]
      },
      "synopsis": {
        "selectors": [
          ".summary p",
          ".summary"
        ],
        "attrs": [
          "text"
        ],
        "cleanup": [
          "stripHTML",
          "decodeEntities",
          "normalizeWhitespace"
        ]
      },
      "cover": {
        "selectors": [
          "div.media div.cover img"
        ],
        "attrs": [
          "data-src",
          "data-original",
          "src"
        ]
      }
    },
    "chapters": {
      "container": "tr:has(.chapter)",
      "title": {
        "selectors": [
          "a"
        ],
        "attrs": [
          "text",
          "title"
        ],
        "cleanup": [
          "decodeEntities",
          "normalizeWhitespace"
        ]
      },
      "url": {
        "selectors": [
          "a"
        ],
        "attrs": [
          "href"
        ],
        "required": true
      },
      "number": {
        "from": "url",
        "regex": "/c([0-9]+(?:\\.[0-9]+)?)"
      },
      "sort": "numberAscending"
    },
    "pages": {
      "extractors": [
        {
          "type": "css",
          "selector": "img",
          "attrs": [
            "data-src",
            "data-original",
            "data-lazy-src",
            "srcset",
            "src"
          ]
        },
        {
          "type": "regex",
          "pattern": "(https?:(?:\\\\/\\\\/|//)[^\"'\\\\\\s]+?\\.(?:jpg|jpeg|png|webp)(?:\\?[^\"'\\\\\\s]*)?)"
        }
      ],
      "filters": {
        "mustContain": [
          ".jpg",
          ".jpeg",
          ".png",
          ".webp"
        ],
        "blockContains": [
          "logo",
          "avatar",
          "placeholder",
          "banner",
          "ads",
          "icon",
          "favicon",
          "sprite",
          "doubleclick",
          "analytics"
        ]
      }
    }
  },
  "discover": {
    "popular": {
      "route": {
        "path": "/"
      },
      "selector": {
        "container": "a[href*=\"/manga/\"]",
        "title": {
          "attrs": [
            "text"
          ],
          "cleanup": [
            "decodeEntities",
            "normalizeWhitespace"
          ]
        },
        "url": {
          "attrs": [
            "href"
          ],
          "required": true
        },
        "cover": {
          "selectors": [
            "img"
          ],
          "attrs": [
            "src",
            "data-src",
            "data-original",
            "data-lazy-src"
          ]
        },
        "htmlScope": {
          "afterRegex": ">\\s*Hot Manga\\s*<",
          "beforeRegex": "<footer\\b"
        }
      }
    },
    "genres": {
      "items": [
        {
          "id": "action",
          "title": "Action",
          "value": "action"
        },
        {
          "id": "romance",
          "title": "Romance",
          "value": "romance"
        },
        {
          "id": "comedy",
          "title": "Comedy",
          "value": "comedy"
        },
        {
          "id": "drama",
          "title": "Drama",
          "value": "drama"
        },
        {
          "id": "fantasy",
          "title": "Fantasy",
          "value": "fantasy"
        },
        {
          "id": "horror",
          "title": "Horror",
          "value": "horror"
        },
        {
          "id": "mystery",
          "title": "Mystery",
          "value": "mystery"
        },
        {
          "id": "sci-fi",
          "title": "Sci-Fi",
          "value": "sci-fi"
        },
        {
          "id": "slice-of-life",
          "title": "Slice of Life",
          "value": "slice-of-life"
        }
      ],
      "operation": {
        "route": {
          "path": "/genre/{{genre}}/page/{page}",
          "pagination": {
            "type": "path",
            "start": 1,
            "maxPages": 1
          }
        },
        "selector": {
          "container": "div#book_list div.item",
          "title": {
            "selectors": [
              "div.text h3 a"
            ],
            "attrs": [
              "text"
            ],
            "cleanup": [
              "decodeEntities",
              "normalizeWhitespace"
            ]
          },
          "url": {
            "selectors": [
              "div.text h3 a"
            ],
            "attrs": [
              "href"
            ],
            "required": true
          },
          "cover": {
            "selectors": [
              "img"
            ],
            "attrs": [
              "data-src",
              "data-original",
              "data-lazy-src",
              "src"
            ]
          }
        }
      }
    }
  },
  "cleanup": {
    "decodeHTMLEntities": true,
    "normalizeWhitespace": true,
    "removeText": [
      "Read Manga Online",
      "Advertisement",
      "[Cover]",
      "Cover"
    ]
  },
  "tests": {
    "query": "one piece",
    "minSearchResults": 1,
    "minChapters": 1,
    "minPages": 1
  }
}
