{
  "schemaVersion": 1,
  "id": "example_api",
  "name": "Example API",
  "version": 1,
  "language": "multi",
  "baseURL": "https://api.example.com",
  "engineMode": "json-api",
  "enabledByDefault": false,
  "experimental": true,
  "allowedDomains": ["api.example.com"],
  "supports": {"search": true, "popular": false, "details": true, "chapters": true, "pages": true},
  "routes": {},
  "selectors": {},
  "api": {
    "search": {"request": {"method": "GET", "path": "/manga", "query": {"q": "{{query}}"}}, "itemsPath": "data", "idPath": "id", "titlePaths": ["title"]},
    "chapters": {"request": {"method": "GET", "path": "/manga/{mangaID}/chapters", "query": {}}, "itemsPath": "data", "idPath": "id", "numberPath": "number", "titlePath": "title", "languagePath": "language", "sort": "numberAscending"},
    "pages": {"request": {"method": "GET", "path": "/chapters/{chapterID}/pages", "query": {}}, "baseURLPath": "baseUrl", "hashPath": "hash", "itemsPath": "pages", "urlTemplate": "{baseURL}/{item}"}
  }
}
